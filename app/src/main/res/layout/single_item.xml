<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    app:cardBackgroundColor="#D3F6A9"
    app:cardElevation="15dp"
    app:cardCornerRadius="20dp"
    android:layout_margin="20dp"

    >


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="15dp">

        <!--        Product name -->

        <TextView
            android:id="@+id/product_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textSize="20sp"
            android:textAlignment="center"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textColor="#000000"

            />

        <!--  Product photo   -->
        <ImageView
            android:id="@+id/product_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/berry"
            android:scaleType="centerCrop"

            />

        <!--  product cost-->

        <TextView
            android:id="@+id/product_cost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KSH 300"
            android:textAlignment="center"
            android:textColor="#2389DB"
            android:textSize="20sp"

            />

        <TextView
            android:id="@+id/product_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available berries all colors that the customer needs at an affrodable price.\n"
            />

        <Button
            android:id="@+id/purchase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Purchase Now"
            android:backgroundTint="#4CAF50"
            android:textSize="20sp"
            android:layout_margin="20dp"

            />




    </LinearLayout>



</androidx.cardview.widget.CardView>